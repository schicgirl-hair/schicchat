const SHEET_NAME="SchicChat Leads";const CLIENT_TOKEN="SCHICCHAT_CLIENT_2026";const ADMIN_TOKEN="CHANGE_THIS_ADMIN_TOKEN_2026";const ADMIN_EMAIL="";const HEADERS=["date","name","contact","country","climate","mainProblem","texture","thickness","density","lastHydration","washFrequency","routine","breakage","porosity","scalp","styles","detangling","products","buildup","heat","water","foodProtein","stressSleep","goal","timeAvailable","score","profile","priority","offer"];function setupSheet(){const sheet=getSheet_();ensureHeaders_(sheet)}function doPost(e){try{const action=getParam_(e,"action"),token=getParam_(e,"token");if(action!=="saveLead")return json_({ok:false,error:"Unknown action"});if(token!==CLIENT_TOKEN)return json_({ok:false,error:"Invalid client token"});const raw=getParam_(e,"data");if(!raw)return json_({ok:false,error:"Missing data"});const lead=JSON.parse(raw);saveLead_(lead);notifyAdmin_(lead);return json_({ok:true})}catch(error){return json_({ok:false,error:error.message})}}function doGet(e){try{if(e.parameter.action==="listLeads"){if(e.parameter.adminToken!==ADMIN_TOKEN)return json_({ok:false,error:"Invalid admin token"});return json_({ok:true,leads:listLeads_()})}return json_({ok:true,message:"SchicChat API is running"})}catch(error){return json_({ok:false,error:error.message})}}function saveLead_(lead){const sheet=getSheet_();ensureHeaders_(sheet);const row=HEADERS.map(key=>{const value=lead[key];if(Array.isArray(value))return value.join(", ");if(value===null||value===undefined)return "";return String(value)});sheet.appendRow(row)}function notifyAdmin_(lead){if(!ADMIN_EMAIL)return;const subject="Nouveau diagnostic SchicChat";const body=`Nouveau lead Schicgirl\n\nNom: ${lead.name||""}\nContact: ${lead.contact||""}\nPays: ${lead.country||""}\nProfil: ${lead.profile||""}\nScore: ${lead.score||""}\nPriorité: ${lead.priority||""}`;MailApp.sendEmail(ADMIN_EMAIL,subject,body)}function listLeads_(){const sheet=getSheet_();ensureHeaders_(sheet);const values=sheet.getDataRange().getValues();if(values.length<=1)return[];const headers=values[0].map(String);return values.slice(1).map(row=>{const obj={};headers.forEach((header,index)=>{obj[header]=row[index] instanceof Date?row[index].toISOString():row[index]});return obj})}function getSheet_(){const ss=SpreadsheetApp.getActiveSpreadsheet();let sheet=ss.getSheetByName(SHEET_NAME);if(!sheet)sheet=ss.insertSheet(SHEET_NAME);return sheet}function ensureHeaders_(sheet){const lastCol=Math.max(sheet.getLastColumn(),HEADERS.length);const firstRow=sheet.getRange(1,1,1,lastCol).getValues()[0];const hasHeaders=firstRow.some(cell=>String(cell||"").trim()!=="");if(!hasHeaders){sheet.getRange(1,1,1,HEADERS.length).setValues([HEADERS]);sheet.setFrozenRows(1)}}function getParam_(e,key){if(e.parameter&&e.parameter[key])return e.parameter[key];if(e.postData&&e.postData.contents){const body=e.postData.contents;if(body.trim().startsWith("{"))return JSON.parse(body)[key]}return""}function json_(obj){return ContentService.createTextOutput(JSON.stringify(obj)).setMimeType(ContentService.MimeType.JSON)}